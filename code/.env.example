# API Key(s) for LLM (Gemini)
# Single key:
GEMINI_API_KEY=your_gemini_api_key_here
# OR multiple keys (comma-separated) — rotated automatically on quota exhaustion:
# GEMINI_API_KEYS=key1,key2,key3

# HuggingFace token (optional but recommended — suppresses rate-limit warnings for model downloads)
HF_TOKEN=your_hf_token_here
